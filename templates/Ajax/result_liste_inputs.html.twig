{{ form_start(form) }}
    <div class="form-grid">
        <div class="input-group">
            {{ form_widget(form.name, {'attr': {'placeholder': ' '}}) }}
            {{ form_label(form.name) }}
        </div>
        {% for key,field in form.connectorParams %}
            <div class="input-group">
                {{ form_widget(field.name) }}
                {% if field.vars.value.name !='wsdl' and field.vars.value.name !='file' %}
                    {{ form_widget(field.value, {'attr': {'placeholder': ' '}}) }}
                {% else %}
                    <a id="link_wsdl" class="fancybox_upload" href="{{ path('upload', {'solution': form.vars.value.solution.name }) }}?file={{ field.vars.value.value }}" data-fancybox-type="iframe">
                        {{ form_widget(field.value, {'id' : 'param_'~field.vars.value.name, 'attr': {'placeholder': ' '}}) }}
                    </a>
                {% endif %}
                {{ form_label(field.value) }}
            </div>
        {% endfor %}
    </div>

    <div class="actions">
        <button type="button" id="{{parent}}_test" class="testing btn btn-test" disabled>
            {{'create_connector.test'|trans}}
        </button>
        <input class="btn btn-save" id="step_modules_confirme" type="submit" value="{{'create_connector.save'|trans}}" disabled/>
    </div>
{{ form_end(form) }}
