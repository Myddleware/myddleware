{% extends 'base.html.twig' %}
{% block title %}{{ parent() }} | {{ 'view_workflow.create'| trans}}{% endblock %}
{% block titlesm %}{{ 'view_workflow.create'| trans}}{% endblock titlesm %}

{% block body %}
    <div class="container mt-5">
        <div class="text-center m-5">
            <a href="{{ path('workflow_list') }}" class="btn btn-outline-warning m-2"> {{ 'view_workflow.cancel'| trans }}</a>
        </div>
        
        {% if app.session.flashBag.has('error_workflow_name') %}
            <div class="alert alert-danger">
                {% for message in app.session.flashBag.get('error_workflow_name') %}
                    {{ message }}
                {% endfor %}
            </div>
        {% endif %}

        {% if not form.vars.valid or app.session.flashBag.has('error_workflow_condition') %}
            <div class="alert alert-danger">
                {% for message in app.session.flashBag.get('error_workflow_condition') %}
                    <div>{{ message }}</div>
                {% endfor %}
                {{ form_errors(form) }}
            </div>
        {% endif %}

        <div class="workflow-details">
            {{ form_start(form) }}
            <div class="mb-3">
                <div class="card-header mb-4 card-title-workflow">
                    {{ 'view_workflow.create'| trans | upper }}
                </div>
                <div class="row mb-4">
                    <div class="col-md-6">
                        {{ form_row(form.name) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.Rule) }}
                    </div>
                </div>
                <div class="row mb-4">
                    <div class="col-md-6">
                        {{ form_row(form.description) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.order) }}
                    </div>
                </div>
                <div class="row mb-4">
                    <div class="col-md-6">
                        {{ form_row(form.active) }}
                    </div>
                </div>
            </div>
        
            <div class="mb-3">
                <div class="card-body">
                    <div class="row mb-4">
                        {{ form_row(form.condition) }}
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-12 text-center">
                    {{ form_row(form.submit) }}
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}