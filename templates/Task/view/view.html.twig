{% extends 'base.html.twig' %}
{% block title %}{{parent()}} | {{'title.task.view'|trans}} {{ task.getId }}{% endblock %}
{% block titlesm %}
    <a href="{{ path('task_list') }}">{{'breadcrumb.task_list'|trans}}</a> 
    <i class="fa-solid fa-arrow-right fa-flip arrow-cut-animation fa-solid fa-arrow-right fa-flip"></i>
{{'title.task.view'|trans}} {{ task.getId }}
{% endblock titlesm %} 
{% block body %}
    <div id="task">
        <button id="task_refresh" type="button" class="btn btn-outline-success mb-3">
            {{'view_task.refresh'|trans}}
        </button>
        <button id="task_stop" type="button" class="btn btn-outline-danger mb-3">
            {{'view_task.task_stop'|trans}}
        </button>
        {# ------------- TASK ------------- #}
        <div align="center" class="table-wrapper m-3">
            {% if task %}

                <table id="headertab" class="table-task-detail">
                    <tr>
                        <th>{{'view_task.header.id'|trans}}</th>
                        <th>{{'view_task.header.status'|trans}}</th>
                        <th class="px-5">{{'list_task.th.param'|trans}}</th>
                        <th>{{'view_task.header.begin'|trans}}</th>
                        <th>{{'view_task.header.end'|trans}}</th>
                        <th>{{'list_task.th.open'|trans}}</th>
                        <th>{{'list_task.th.close'|trans}}</th>
                        <th>{{'list_task.th.cancel'|trans}}</th>
                        <th>{{'list_task.th.error'|trans}}</th>
                        <th>{{'list_task.th.manual'|trans}}</th>
                        <th>{{'list_task.th.api'|trans}}</th>
                        <th class="px-5">{{'view_task.header.message'|trans}}</th>
                    </tr>
                    <tr>
                        <td class="ctr">{{ task.getId }}</td>
                        <td class="ctr">
                            {% if task.getStatus|lower == 'end' %}
                            <span id="task_status" class="label label-default" name="{{ task.getStatus }}">{{ task.getStatus }}</span>
                            {% else %}
                            <span id="task_status" class="label label-warning" name="{{ task.getStatus }}">{{ task.getStatus }}</span>
                            {% endif %}
                        </td>
                        <td class="ctr">
                            <div id="param_task_short">
                                {{ task.getParam|slice(0, 30) ~ '...' }}
                            </div>
                            <div id="param_task_collapse" style="display:none;">
                                {{ task.getParam }}
                            </div>
                            <div style="margin-top: 5px;">
                                <button onclick="toggleParam()" class="toggleparam-task"><i class="fa fa-plus" aria-hidden="true"></i></button>
                            </div>
                        </td>
                        <td class="ctr">
                            {% if task.getBegin is null %}
                                -
                            {% else %}
                                {{ task.getBegin|date(app.user.dateFormat ~ " H:i:s", app.user.timezone) }}
                            {% endif %}
                        </td>
                        <td class="ctr">
                            {% if task.getEnd is null %}
                                -
                            {% else %}
                                {{ task.getEnd|date(app.user.dateFormat ~ " H:i:s", app.user.timezone) }}
                            {% endif %}
                        </td>
                        <td class="ctr">{{ task.getOpen }}</td>
                        <td class="ctr">{{ task.getClose }}</td>
                        <td class="ctr">{{ task.getCancel }}</td>
                        <td class="ctr">{{ task.getError }}</td>
                        <td class="ctr">{{ task.getManual }}</td>
                        <td class="ctr">{{ task.getApi }}</td>
                        <td class="ctr">
                            <div id="message_task_short">
                                {{ task.getMessage|slice(0, 30) ~ '...' }}
                            </div>
                            <div id="message_task_collapse" style="display:none;">
                                {{ task.getMessage }}
                            </div>
                            <div style="margin-top: 5px;">
                                <button onclick="toggleMessage()" class="toggleparam-task"><i class="fa fa-plus" aria-hidden="true"></i></button>
                            </div>
                        </td>
                    </tr>
                </table>
            {% endif %}
        </div>
        {# ------------- TASK ------------- #}

        {% if nb > 0 %}
        <section class="data-wrapper parent-documents-section mb-3">
            <div class="parent-documents-header">
                <h3>📄 {{'view_task.nblogs'|trans}}<span class="nb"> ({{ nb }})</span></h3>
            </div>
            {% endif %}     
        <section>
        {# ------------- MESSAGE ------------- #}
        <div id="message" align="center">

            {% if nb > 0 %}     
    
                <table class="logs-table">
                    <thead>
                    {% if entities is not empty %}  
                        <tr>
                            <th>{{'view_task.log.id'|trans}}</th>
                            <th>{{'view_task.log.ref'|trans}}</th>
                            <th>{{'view_task.log.transfer'|trans}}</th>
                            <th>{{'view_task.log.date_created'|trans}}</th>
                            <th>{{'view_task.log.type'|trans}}</th>
                            <th>{{'view_task.log.msg'|trans}}</th>
                        </tr> 
                    
                    </thead>
                    <tbody>
                        {% for log in entities %}
                        <tr class="fd_log_{{ log.getType|lower }}">
                        <td class="ctr">
                            {{ log.getId }} 
                        </td>
                        <td>                                            
                            {% if log.getRef is not empty %}    
                                    <a onclick="window.open(this.href); return false;" href="{{ path('flux_modern', {'id': log.getRef }) }}">
                                        {{ log.getRef }}
                                    </a>
                            {% else %}
                                {{ log.getRef }}
                            {% endif %}
                        </td>   
                        <td>
                            {% if log.getDocument is not empty %}
                                <a href="{{ path('flux_modern', {'id': log.getDocument.id }) }}">{{ log.getDocument.id }}</a>
                            {% endif %}
                        </td>                                                                                                            
                        <td>{{ log.getCreated|date(app.user.dateFormat ~ " H:i:s", app.user.timezone) }}</td>
                        <td class="ctr">
                            <div class="log_{{ log.getType|lower }}">{{ log.getType }}
                            {% if log.getType|lower == 's' %}
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check" viewBox="0 0 16 16">
                                <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425a.267.267 0 0 1 .02-.022z"/>
                                </svg>
                            {% elseif log.getType|lower == 'e' %}
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x" viewBox="0 0 16 16">
                                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                                </svg>
                                {% elseif log.getType|lower == 'w' %}
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation" viewBox="0 0 16 16">
                                    <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.553.553 0 0 1-1.1 0L7.1 4.995z"/>
                                    </svg>
                            {% endif %}
                            </div>
                        </td>
                        <td class="msg">
                            {{ log.getMessage }}
                        </td>                                               
                        </tr>   
                            
                        {% endfor %}    
                    </tbody>                    
                    {% endif %}
                </table>
                <div class="d-flex justify-content-center mt-4">
                    {% if pager.haveToPaginate %}
                        <div class="d-flex justify-content-center mt-4">
                            {% if pager.haveToPaginate %}
                                {{ pagerfanta(pager, 'twitter_bootstrap4', { 'routeParams' : { 'id': task.getId }, 'routeName': 'task_view_page' } ) }}
                            {% endif %}
                        </div>                        
                    {% endif %}
                </div>       
                {% else %}
                <p>{{'view_task.empty_log'|trans}}</p>
                {% endif %}

        </div>
        {# ------------- MESSAGE ------------- #}
    </div>

    {# ------------- PARAMETRES JQUERY ------------- #}
    <script type="text/javascript">     
    var path_img = "{{ asset('build/images/regle/') }}";
    var path_task_stop = "{{ path('task_stop',{'id' : task.getId }) }}";
    
    function toggleMessage() {
        var fullDiv = document.getElementById('message_task_collapse');
        var shortDiv = document.getElementById('message_task_short');
        
        if (fullDiv.style.display === "none") {
            fullDiv.style.display = "block";
            shortDiv.style.display = "none";
        } else {
            fullDiv.style.display = "none";
            shortDiv.style.display = "block";
        }
    }
    
    function toggleParam() {
        var fullDiv = document.getElementById('param_task_collapse');
        var shortDiv = document.getElementById('param_task_short');
        
        if (fullDiv.style.display === "none") {
            fullDiv.style.display = "block";
            shortDiv.style.display = "none";
        } else {
            fullDiv.style.display = "none";
            shortDiv.style.display = "block";
        }
    }
    </script>
    {# ------------- PARAMETRES JQUERY ------------- #}
{% endblock %}