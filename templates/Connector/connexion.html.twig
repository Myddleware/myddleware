<div class="modern-connector-layout view-create-page">
    <div class="connector-card"> 
        <div class="connector-left" id="source"> 
            <select id="soluce_source" class="liste_solution">
                {{ solutions | raw }}
            </select>
            <div class="logo-wrapper">
                <div class="picture"></div> 
            </div>
            <div id="source_status" style="display:none;"><img src=""></div>
            <div id="source_msg" style="display:none;"><span></span></div>
            <div class="help"></div> 
            <div class="champs"></div>
        </div>

        <div class="connector-right">
            <div></div> 
            <div id="msg_status" class="alert alert-danger" style="display:none; margin-top:15px;">
                <i class="fa fa-exclamation-circle"></i> <span class="error"></span>
            </div>
        </div>
    </div>
</div>
{% block base_js %}
    <script type="text/javascript">
        var path_link_fr = "{{'view_connector.help.link'|trans}}";
    </script>
{% endblock base_js %}