<div id="source">
	<div class="connector-card">
		<div class="card-left">
			<div class="app-selector">
				<select id="soluce_source" class="liste_solution">
					{{solutions | raw }}
				</select>
			</div>
			<div class="picture app-icon"></div>
		</div>
		<div class="card-right">
			<h2 class="connector-config-title"></h2>
			<div class="champs"></div>
			<div class="help"></div>
		</div>
	</div>
</div>

<div id="msg_status" class="alert alert-danger" role="alert">
	<i class="fa fa-exclamation" aria-hidden="true"></i>
	{{'error.connexion'|trans}} : <span class="error"></span>
</div>

{% block base_js %}
	<script type="text/javascript">
		var path_link_fr = "{{'view_connector.help.link'|trans}}";
	</script>
{% endblock base_js %}
